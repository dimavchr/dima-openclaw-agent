{
  "agents": {
    "defaults": {
      "workspace": "/home/node/.openclaw/workspace",
      "model": {
        "primary": "deepseek/deepseek-v4-flash",
        "fallbacks": [
          "google/gemini-3.1-flash-lite",
          "google/gemini-2.5-flash",
          "google/gemini-2.0-flash"
        ]
      },
      "models": {
        "deepseek/deepseek-v4-flash": {
          "alias": "DeepSeek V4 Flash"
        },
        "deepseek/deepseek-v4-pro": {
          "alias": "DeepSeek V4 Pro"
        },
        "google/gemini-3.1-flash-lite": {
          "alias": "Gemini 3.1 Flash Lite"
        },
        "google/gemini-2.5-flash": {
          "alias": "Gemini 2.5 Flash"
        },
        "google/gemini-2.0-flash": {
          "alias": "Gemini 2.0 Flash"
        },
        "google/gemini-3.1-pro-preview": {
          "alias": "Gemini 3.1 Pro Preview"
        },
        "google/gemini-3-flash-preview": {
          "alias": "Gemini 3 Flash Preview"
        }
      },
      "compaction": {
        "notifyUser": true,
        "memoryFlush": {
          "enabled": true,
          "softThresholdTokens": 8000
        }
      },
      "memorySearch": {
        "provider": "gemini",
        "model": "gemini-embedding-001",
        "remote": {
          "apiKey": "__GOOGLE_API_KEY__"
        }
      }
    }
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "__GATEWAY_TOKEN__"
    },
    "port": 18789,
    "bind": "loopback",
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://localhost:18789",
        "http://127.0.0.1:18789"
      ]
    },
    "nodes": {
      "denyCommands": [
        "camera.snap",
        "camera.clip",
        "screen.record",
        "contacts.add",
        "calendar.add",
        "reminders.add",
        "sms.send",
        "sms.search"
      ]
    }
  },
  "messages": {
    "tts": {
      "enabled": true,
      "providers": {
        "google": {
          "voiceName": "Vindemiatrix",
          "personaPrompt": "Speak with the confident, expressive energy of a sassy Black woman. Be animated and rhythmic in your delivery — warm but direct, with natural attitude. Put emphasis on key words, let your personality come through your inflection, and lean into the drama when the moment calls for it. Use natural vocal flair: a bit of side-eye in the tone when something is obvious, warmth when encouraging, and unapologetic confidence throughout."
        }
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "profile": "coding",
    "allow": ["tts"]
  },
  "plugins": {
    "entries": {
      "google": {
        "enabled": true
      },
      "telegram": {
        "enabled": true
      },
      "canvas": {
        "enabled": true,
        "config": {
          "host": {
            "enabled": true
          }
        }
      },
      "searxng": {
        "enabled": true,
        "config": {
          "webSearch": {
            "baseUrl": "http://searxng:8080"
          }
        }
      }
    }
  },
  "auth": {
    "profiles": {
      "google:default": {
        "provider": "google",
        "mode": "api_key"
      }
    }
  },
  "channels": {
    "telegram": {
      "enabled": true,
      "groups": {
        "*": {
          "requireMention": true
        }
      },
      "botToken": "__TELEGRAM_BOT_TOKEN__",
      "groupPolicy": "open",
      "reactionNotifications": "own",
      "actions": {
        "reactions": true
      }
    }
  },
  "commands": {
    "ownerAllowFrom": [
      "telegram:__TELEGRAM_OWNER_ID__",
      "telegram:__TELEGRAM_OWNER_ID_2__"
    ]
  },
  "models": {
    "providers": {
      "openrouter": {
        "baseUrl": "https://openrouter.ai/api/v1",
        "apiKey": "__OPENROUTER_API_KEY__",
        "api": "openai-completions",
        "headers": {
          "HTTP-Referer": "https://github.com/openclaw/openclaw",
          "X-Title": "DAISHA Assistant"
        },
        "models": [
          {
            "id": "deepseek/deepseek-chat",
            "name": "DeepSeek Chat"
          },
          {
            "id": "meta-llama/llama-3.3-70b-instruct:free",
            "name": "Llama 3.3 70B (free)"
          },
          {
            "id": "qwen/qwen3-coder:free",
            "name": "Qwen3 Coder (free)"
          }
        ]
      },
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "__DEEPSEEK_API_KEY__",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-v4-flash",
            "name": "DeepSeek V4 Flash"
          },
          {
            "id": "deepseek-v4-pro",
            "name": "DeepSeek V4 Pro"
          },
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat (legacy, deprecated Jul 24)"
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek Reasoner (legacy, deprecated Jul 24)"
          }
        ]
      },
      "google": {
        "baseUrl": "https://generativelanguage.googleapis.com/v1beta/openai/",
        "apiKey": "__GOOGLE_API_KEY__",
        "api": "openai-completions",
        "models": [
          {
            "id": "gemini-3.1-flash-lite",
            "name": "Gemini 3.1 Flash Lite"
          },
          {
            "id": "gemini-2.5-flash",
            "name": "Gemini 2.5 Flash"
          },
          {
            "id": "gemini-2.0-flash",
            "name": "Gemini 2.0 Flash"
          },
          {
            "id": "gemini-3.1-pro-preview",
            "name": "Gemini 3.1 Pro Preview"
          },
          {
            "id": "gemini-3-flash-preview",
            "name": "Gemini 3 Flash Preview"
          }
        ]
      }
    }
  }
}
